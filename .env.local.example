# ============================================================
# VARIÁVEIS DE AMBIENTE — copie este arquivo para .env.local
# e preencha com seus valores reais
# ============================================================

# Chave da API do Claude (Anthropic) — para reescrever notícias
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave da NewsAPI — para buscar notícias automaticamente (GRÁTIS)
# Obtenha em: https://newsapi.org/register
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token do GitHub — para salvar as notícias no repositório
# Obtenha em: https://github.com/settings/tokens (marque permissão "repo")
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nome do seu repositório no formato: SEU_USUARIO/miami-brasileiro
GITHUB_REPO=seunome/miami-brasileiro

# Senha secreta para proteger o endpoint de busca de notícias
# Invente qualquer senha forte aqui
CRON_SECRET=minha-senha-super-secreta-aqui
